# Service
RECO_HOST=0.0.0.0
RECO_PORT=8000
RECO_LOG_LEVEL=info

# Auth interne (Next.js → Python) — optionnel en dev
RECO_INTERNAL_API_KEY=

# Supabase (catalogue agents + RPC vectorielle)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Embeddings (Jina v3, 1024 dims)
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-embeddings-v3

# LLM — Qwen 235B (prioritaire, comme stackai)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
CEREBRAS_MODEL_FALLBACK=gpt-oss-120b

# LLM Groq (secours)
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GROQ_MODEL_FALLBACK=llama-3.3-70b-versatile

# Filtre catalogue (Docker: /app/data/catalog-filter.json)
# CATALOG_FILTER_PATH=

# CORS — URL(s) Next.js autorisées, séparées par des virgules
RECO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

RECO_DRY_RUN=false
# false = pas de plan heuristique silencieux si le LLM échoue (erreur 503 explicite)
RECO_ALLOW_HEURISTIC_FALLBACK=false
RECO_LLM_PASS1_ATTEMPTS=2
RECO_LLM_STEP_DELAY_MS=500
